{
  "expo": {
    "name": "MecânicaPro",
    "slug": "mecanicapro-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#0f1115"
    },
    "userInterfaceStyle": "dark",
    "backgroundColor": "#0f1115",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.mecanicapro.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0f1115"
      },
      "package": "com.mecanicapro.app"
    },
    "web": {
      "bundler": "metro"
    },
    "owner": "hudraf",
    "plugins": [
      "expo-secure-store"
    ],
    "extra": {
      "eas": {
        "projectId": "87af8212-d969-4de7-af19-2916c5c26f1b"
      }
    }
  }
}
